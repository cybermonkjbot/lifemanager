{
  "name": "odogwuhq",
  "version": "0.1.0",
  "description": "AI communication double that can reply in your style across WhatsApp and Instagram.",
  "private": true,
  "author": "Marvengrey technologies Nig LTD",
  "license": "SEE LICENSE IN LICENSE",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cybermonkjbot/lifemanager.git"
  },
  "bugs": {
    "url": "https://github.com/cybermonkjbot/lifemanager/issues"
  },
  "homepage": "https://github.com/cybermonkjbot/lifemanager#readme",
  "main": "src/desktop/main.mjs",
  "bin": {
    "OdogwuHQ": "scripts/lifemanager-installer.mjs",
    "odogwuhq": "scripts/lifemanager-installer.mjs",
    "lifemanager": "scripts/lifemanager-installer.mjs"
  },
  "files": [
    ".env.example",
    "AGENTS.md",
    "CHANGELOG.md",
    "CODE_OF_CONDUCT.md",
    "CONTRIBUTING.md",
    "LICENSE",
    "NOTICE",
    "README.md",
    "RELEASE.md",
    "SECURITY.md",
    "SUPPORT.md",
    "TRADEMARKS.md",
    "USE_POLICY.md",
    "bun.lock",
    "convex",
    "convex.json",
    "data",
    "docs",
    "electron-builder.yml",
    "!docs/linkedin-product-launch-social-life-manager.md",
    "eslint.config.mjs",
    "next.config.ts",
    "package.json",
    "postcss.config.mjs",
    "proxy.ts",
    "public",
    "scripts",
    "self-improvement.config.json",
    "shared",
    "src",
    "tsconfig.json"
  ],
  "scripts": {
    "dev": "bun run dev:next",
    "dev:next": "mkdir -p .slm && sh -lc 'echo $$ > .slm/app.pid; exec next dev'",
    "dev:convex": "bunx convex dev",
    "worker": "bun run src/worker/supervisor.ts whatsapp",
    "worker:raw": "bun run src/worker/index.ts",
    "worker:instagram": "bun run src/worker/supervisor.ts instagram",
    "worker:instagram:raw": "bun run src/worker/instagram.ts",
    "worker:imessage": "bun run src/worker/supervisor.ts imessage",
    "worker:imessage:raw": "bun run src/worker/imessage.ts",
    "worker:telegram": "bun run src/worker/supervisor.ts telegram",
    "worker:telegram:raw": "bun run src/worker/telegram.ts",
    "desktop:dev": "ODOGWU_DESKTOP_DEV=1 electron src/desktop/main.mjs",
    "desktop:dev:no-worker": "ODOGWU_DESKTOP_DEV=1 ODOGWU_DESKTOP_START_WORKER=0 electron src/desktop/main.mjs",
    "desktop:prepare:standalone": "node scripts/prepare-desktop-build.mjs",
    "desktop:build:next": "bun run build && bun run desktop:prepare:standalone",
    "desktop:build:connector": "node scripts/build-desktop-connector.mjs",
    "desktop:build": "bun run desktop:build:next && bun run desktop:build:connector",
    "desktop:package": "bun run desktop:build && electron-builder --dir",
    "desktop:dist": "bun run desktop:build && electron-builder",
    "desktop:dist:mac": "bun run desktop:build && electron-builder --mac --x64 --arm64",
    "desktop:dist:win": "bun run desktop:build && electron-builder --win --x64",
    "desktop:dist:all": "bun run desktop:build && electron-builder --mac --x64 --arm64 && electron-builder --win --x64",
    "pidgin:refresh": "bun run scripts/pidgin-lexicon-refresh.ts",
    "pidgin:promote": "bun run scripts/pidgin-lexicon-promote.ts",
    "pidgin:refresh-and-promote": "bun run scripts/pidgin-lexicon-refresh.ts --write --out data/pidgin-lexicon-candidates.json && bun run scripts/pidgin-lexicon-promote.ts --write",
    "self-improve": "bun run scripts/self-improvement-cycle.ts once",
    "self-improve:daemon": "bun run scripts/self-improvement-cycle.ts daemon",
    "dev:all": "concurrently -n next,convex,worker-wa,worker-ig -c cyan,magenta,yellow,green \"bun run dev:next\" \"bun run dev:convex\" \"bun run worker\" \"bun run worker:instagram\"",
    "build": "next build",
    "start": "mkdir -p .slm && sh -lc 'echo $$ > .slm/app.pid; exec next start'",
    "lint": "bunx eslint .",
    "test": "bun test $(find ./src ./convex ./shared \\( -name '*.test.ts' -o -name '*.test.tsx' \\) -print)",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@azure-rest/ai-inference": "^1.0.0-beta.6",
    "@azure/core-auth": "^1.10.1",
    "@codemirror/autocomplete": "^6.20.1",
    "@codemirror/language": "^6.12.3",
    "@codemirror/lint": "^6.9.5",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.41.1",
    "@lezer/highlight": "^1.2.3",
    "@photon-ai/imessage-kit": "^3.0.0",
    "@splinetool/react-spline": "^4.1.0",
    "@xenova/transformers": "^2.17.2",
    "baileys": "^7.0.0-rc.9",
    "clsx": "^2.1.1",
    "convex": "^1.34.1",
    "convex-helpers": "^0.1.114",
    "date-fns": "^4.1.0",
    "electron-updater": "^6.8.3",
    "instagram-private-api": "^1.46.1",
    "next": "16.2.2",
    "pdf-parse": "^2.4.5",
    "pino": "^10.3.1",
    "qrcode": "^1.5.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "telegram": "^2.26.22",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "concurrently": "^9.2.1",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "sharp",
    "unrs-resolver"
  ]
}
