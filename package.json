{
  "name": "lifemanager",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "bun run dev:next",
    "dev:next": "mkdir -p .slm && sh -lc 'echo $$ > .slm/app.pid; exec next dev'",
    "dev:convex": "convex dev",
    "worker": "bun run src/worker/index.ts",
    "pidgin:refresh": "bun run scripts/pidgin-lexicon-refresh.ts",
    "pidgin:promote": "bun run scripts/pidgin-lexicon-promote.ts",
    "pidgin:refresh-and-promote": "bun run scripts/pidgin-lexicon-refresh.ts --write --out data/pidgin-lexicon-candidates.json && bun run scripts/pidgin-lexicon-promote.ts --write",
    "self-improve": "bun run scripts/self-improvement-cycle.ts once",
    "self-improve:daemon": "bun run scripts/self-improvement-cycle.ts daemon",
    "dev:all": "concurrently -n next,convex,worker -c cyan,magenta,yellow \"bun run dev:next\" \"bun run dev:convex\" \"bun run worker\"",
    "build": "next build",
    "start": "mkdir -p .slm && sh -lc 'echo $$ > .slm/app.pid; exec next start'",
    "lint": "eslint"
  },
  "dependencies": {
    "@azure-rest/ai-inference": "^1.0.0-beta.6",
    "@xenova/transformers": "^2.17.2",
    "@azure/core-auth": "^1.10.1",
    "@splinetool/react-spline": "^4.1.0",
    "baileys": "^7.0.0-rc.9",
    "clsx": "^2.1.1",
    "convex": "^1.34.1",
    "convex-helpers": "^0.1.114",
    "date-fns": "^4.1.0",
    "next": "16.2.2",
    "pino": "^10.3.1",
    "qrcode": "^1.5.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "concurrently": "^9.2.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "sharp",
    "unrs-resolver"
  ]
}
